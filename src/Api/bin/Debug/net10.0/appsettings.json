{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=SalaoCabeleleila;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "Secret": "CabeleleilaLeila_SuperSecretKey_2026_Min32Chars!",
    "Issuer": "SalaoCabeleleila",
    "Audience": "SalaoCabeleleilaClient",
    "ExpirationHours": 8
  },
  "ModalTitleConfig": {
    "GeneralSuccess": "Sucesso",
    "Congrats": "Parabéns",
    "PasswordChanged": "Senha alterada",
    "PasswordReseted": "Senha redefinida",
    "SentMail": "E-mail enviado",
    "SentMessage": "Mensagem enviada",
    "Error": "Erro",
    "FormError": "Erro no formulário",
    "PreRegisterGenericError": "Erro no pré-cadastro",
    "ChangedUserSuccess": "Usuário alterado com sucesso",
    "ProjectName": "Cabeleleila Leila"
  },
  "SalaoHorarioConfig": {
    "HoraAbertura": "08:00",
    "HoraFechamento": "18:00",
    "IntervaloMinutos": 30
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
